# == ArtPortal v2 Environment Config ==========================================
# Copy this file to .env and adjust values before running.

# Database — swap to PostgreSQL when scaling:
# DATABASE_URL=postgresql://user:password@localhost:5432/artportal
DATABASE_URL=sqlite:////app/data/artportal.db

# JWT — MUST change in production (min 32 chars)
SECRET_KEY=artportal_super_secret_key_v1_secure_2026
ALGORITHM=HS256
TOKEN_EXPIRE_HOURS=12

# OCR — min text blocks before skipping to next OCR stage
OCR_THRESHOLD=5

# AI — cosine similarity cutoff for "Unknown" label
AI_THRESHOLD=0.75

# Tesseract path — only needed if tesseract.exe is NOT in system PATH
# Windows default install path:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
